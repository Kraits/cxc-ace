# ── Turso Cloud Database (for Vercel / production) ─────────────
# 1. Sign up at https://turso.tech/app
# 2. Create a database named "cxc-ace"
# 3. Copy the URL and token from the dashboard
# 4. Paste them below

DATABASE_URL="libsql://cxc-ace-XYZ.turso.io"
DATABASE_AUTH_TOKEN="your-turso-auth-token-here"

# ── Local development (optional) ───────────────────────────────
# For local dev, you can use a local SQLite file instead:
# DATABASE_URL="file:./db/cxc.db"
# (remove DATABASE_AUTH_TOKEN when using local file)
