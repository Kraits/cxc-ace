# Database URL
# ──────────────────────────────────────────
# LOCAL development (SQLite file):
DATABASE_URL="file:./db/cxc.db"

# PRODUCTION (Turso cloud database):
# 1. Install Turso CLI: curl -sSfL https://get.tur.so/install.sh | bash
# 2. Create account:  turso auth login
# 3. Create database: turso db create cxc-ace
# 4. Get auth token:   turso db tokens create cxc-ace
# 5. Get URL:          turso db show cxc-ace --url
# 6. Set env vars:
# DATABASE_URL="libsql://cxc-ace-your-org.turso.io"
# DATABASE_AUTH_TOKEN="your-turso-auth-token"
